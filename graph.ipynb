import numpy as np
import pandas as pd
import matplotlib.pyplot as plt

# ----------------------------------------------------
# 1. 製造業の「汚いセンサーデータ」をシミュレーション作成
# ----------------------------------------------------
print("1. 汚いダミーデータの作成中...")
np.random.seed(42)
time_range = pd.date_range(start="2026-06-01 09:00:00", end="2026-06-01 09:10:00", freq="1S")
n_samples = len(time_range)

# 基本となるきれいな信号（温度変化のトレンド）
base_signal = 20.0 + np.sin(np.linspace(0, 3 * np.pi, n_samples)) * 5

# 激しい測定ノイズを付与
noise = np.random.normal(0, 0.8, n_samples)
dirty_temp = base_signal + noise

# 意図的に「通信不良によるデータ欠損(NaN)」を作る
nan_mask = np.random.rand(n_samples) < 0.15  # 15%の確率で欠損
dirty_temp[nan_mask] = np.nan

# 意図的に「異常な突発スパイク（ノイズ）」を入れる（例：センサーの一瞬の誤作動）
spike_indices = np.random.choice(n_samples, size=5, replace=False)
dirty_temp[spike_indices] = dirty_temp[spike_indices] + np.random.choice([8.0, -8.0], size=5)

# DataFrame化
df = pd.DataFrame({"raw_temp": dirty_temp}, index=time_range)

# ----------------------------------------------------
# 2. クレンジング & 特徴量エンジニアリング
# ----------------------------------------------------
print("2. クレンジング処理（リサンプル ＆ 補間）を開始...")

# 【リサンプル】 5秒間隔のデータに集計（平均値）し、時間軸をきれいに等間隔に揃える
# これにより、秒単位の激しいノイズを少し慣らしつつ、時間軸を整えます
df_resampled = df.resample("5S").mean()

# 【欠損値補間】 リサンプルによって発生した、または元からあった NaN を線形補間（滑らかに繋ぐ）
df_resampled["cleaned_temp"] = df_resampled["raw_temp"].interpolate(method="linear")

# 【ローリング】 30秒窓（6行分: 5秒×6 = 30秒）の移動平均でノイズを平滑化
# これが「綺麗にトレンドを取り出したデータ」になります
df_resampled["rolling_mean"] = df_resampled["cleaned_temp"].rolling(window=6, min_periods=1).mean()

# 【ローリング特徴量】 30秒窓の移動標準偏差（値のばらつき・ブレ）を計算
# プレスの衝撃や異常振動などの「ばらつきの急増」を検知するための特徴量になります
df_resampled["rolling_std"] = df_resampled["cleaned_temp"].rolling(window=6, min_periods=1).std()

# ----------------------------------------------------
# 3. Matplotlib を使った視覚的検証（プロット）
# ----------------------------------------------------
print("3. 結果の可視化グラフを作成中...")
fig, (ax1, ax2) = plt.subplots(2, 1, figsize=(10, 8), sharex=True)

# 上のグラフ: 生データとクレンジング後データの比較
ax1.plot(df.index, df["raw_temp"], label="1. Raw (Noisy & Missing)", color="gray", alpha=0.4, linestyle=":")
ax1.plot(df_resampled.index, df_resampled["cleaned_temp"], label="2. Cleaned (Resampled & Interpolated)", color="orange", alpha=0.7)
ax1.plot(df_resampled.index, df_resampled["rolling_mean"], label="3. Rolling Mean (30s Window)", color="blue", linewidth=2)
ax1.set_title("Manufacturing Sensor Temperature Cleaning", fontsize=14, fontweight="bold")
ax1.set_ylabel("Temperature (°C)")
ax1.legend(loc="upper right")
ax1.grid(True, linestyle="--", alpha=0.6)

# 下のグラフ: ばらつき（移動標準偏差）の推移
# これを見ることで、「どの時間帯に値が激しくブレていたか」が一目で分かります
ax2.plot(df_resampled.index, df_resampled["rolling_std"], label="Rolling Std (Fluctuation Indicator)", color="red", linewidth=1.5)
ax2.set_ylabel("Temperature Std Dev")
ax2.set_xlabel("Time")
ax2.legend(loc="upper right")
ax2.grid(True, linestyle="--", alpha=0.6)

plt.tight_layout()

# 結果を画像として保存（ワークスペース内で直接見られるようにします）
output_img = "sensor_cleaning_result.png"
plt.savefig(output_img, dpi=150)
print(f"🎉 処理完了！グラフを '{output_img}' に保存しました。")
